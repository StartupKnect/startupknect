# Contact form email delivery (Resend — https://resend.com)
# Without RESEND_API_KEY the /api/contact route validates and accepts
# submissions but only logs them (handy for local/preview).
RESEND_API_KEY=
# Where enquiries are delivered (defaults to hello@startupknect.in)
CONTACT_TO_EMAIL=hello@startupknect.in
# Verified sender. Use a domain you've verified in Resend in production.
CONTACT_FROM_EMAIL="StartupKnect <onboarding@resend.dev>"
